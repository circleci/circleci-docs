{{#if page.component.versions.[1]}}
  {{#with (component-versions-to-nav page.component) }} 
    <div data-dropdown class="relative flex font-normal w-1/2 mt-6 mb-8 mr-2">
      <!-- Trigger Button -->
      <button
        data-dropdown-button
        class="px-2 py-2 border rounded-[8px] border-vapor text-left flex items-center justify-between focus:border-link-on-light hover:border-link-on-light"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <span data-dropdown-selected>{{#if ./selected}}{{./selected}}{{else}}{{@root.page.component.title}}{{/if}}</span>
        <svg width="6" height="4" viewBox="0 0 6 4" fill="none" xmlns="http://www.w3.org/2000/svg" class="ml-2 w-[8px] h-[8px]" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M3.35355 3.85355C3.15829 4.04882 2.84171 4.04882 2.64645 3.85355L0.146447 1.35355C-0.0488155 1.15829 -0.0488155 0.841708 0.146447 0.646446C0.341709 0.451184 0.658292 0.451184 0.853554 0.646446L3 2.79289L5.14645 0.646447C5.34171 0.451184 5.65829 0.451184 5.85355 0.646447C6.04882 0.841709 6.04882 1.15829 5.85355 1.35355L3.35355 3.85355Z" fill="currentColor"/>
        </svg>
      </button>

      <!-- Dropdown Menu -->
      {{> dropdown-menu navList=./navList }}
    </div>
  {{/with}}
{{/if}}
