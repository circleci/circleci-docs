<div class="mt-5 mb-10 lg:mt-0 w-full md:w-fit max-w-full md:px-4 flex flex-col md:flex-row border border-vapor rounded-xl items-stretch justify-between {{#if class}}{{class}}{{/if}}">
  {{#with (get-page-meta page)}}

    <div class="flex items-center pl-3 md:pl-0 pr-3 py-2">
      <!-- Article Last Updated -->
      {{#if lastUpdate}}
        <a href="{{commitUrl}}" class="flex min-w-fit items-center text-link-on-light">
          <svg class="inline-block h-5 w-5 mr-2" viewBox="0 0 18 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M4 0C4.55228 0 5 0.447715 5 1V2H13V1C13 0.447715 13.4477 0 14 0C14.5523 0 15 0.447715 15 1V2H16C17.1046 2 18 2.89543 18 4V18C18 19.1046 17.1046 20 16 20H2C0.895431 20 0 19.1046 0 18V4C0 2.89543 0.895431 2 2 2H3V1C3 0.447715 3.44772 0 4 0ZM2 7V18H16V7H2ZM5 9H8C8.55228 9 9 9.44772 9 10V13C9 13.5523 8.55228 14 8 14H5C4.44772 14 4 13.5523 4 13V10C4 9.44772 4.44772 9 5 9Z" fill="currentColor"/>
          </svg>
          {{format-time-ago lastUpdate}}
        </a>
      {{/if}}
      <!-- Read Time -->
      {{#if @root.page.attributes.show-readtime}}
        {{#if readingTime}}
          <span class="text-xl px-2">&middot;</span>
          <span class="flex min-w-fit items-center">
            {{readingTime}}
          </span>
        {{/if}}
      {{/if}}
    </div>
  {{/with}}

  <!-- Platform Tags -->
  {{#if page.attributes.platform}}
    <div class="flex items-center min-w-fit space-x-1 px-3 py-2 md:py-0 border-t md:border-t-0 md:border-l border-inherit">
      {{#each (split page.attributes.platform ',')}}
        <span class="text-[10px] text-terminal-black border rounded-full py-1 px-1.5" style="font-family: 'Roboto', sans-serif; font-weight: 700;">{{this}}</span>
      {{/each}}
    </div>
  {{/if}}
  <!-- Copy Markdown Link -->
  <div class="flex items-center py-2 md:py-0 pl-3 min-w-fit border-t md:border-t-0 md:border-l border-inherit">
    <button class="copy-markdown-link text-link-on-light text-[16px] font-medium bg-transparent border-none cursor-pointer p-0 focus:outline-none">
      Copy markdown
    </button>
  </div>
</div>