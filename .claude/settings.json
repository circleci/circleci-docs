{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init.",
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 npm ci",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 task test",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 task lint",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 task fmt",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chunk validate",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
